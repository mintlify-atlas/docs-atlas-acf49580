  "keyFeatures": [
    "Topic-based threading for organized conversations",
    "Powerful message formatting with Markdown",
    "Real-time synchronization across devices",
    "Extensive webhook and bot integrations",
    "Enterprise-grade authentication (SAML, LDAP, OAuth)",
    "Self-hosting with Docker and native installation",
    "Open-source with Apache 2.0 license",
    "Mobile apps for iOS and Android"
  ],
  "publicApiSurface": [
    "POST /api/v1/messages - Send messages",
    "GET /api/v1/messages - Retrieve messages",
    "PATCH /api/v1/messages/{message_id} - Update messages",
    "GET /api/v1/streams - List streams",
    "POST /api/v1/users - Create users",
    "GET /api/v1/users - List users",
    "POST /api/v1/register - Register event queue",
    "GET /api/v1/events - Get events",
    "POST /api/v1/users/me/subscriptions - Subscribe to streams",
    "POST /api/v1/external/* - Webhook integrations"
  ]
